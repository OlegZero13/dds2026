# Copy to .env and fill in. No API keys, no signups.

# The shared model endpoint handed out at the start of the workshop.
# To run fully offline instead, install Ollama and use http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Model served by that endpoint.
MODEL_ID=llama3.1:8b

# Optional: grade the agent-as-judge module with a SEPARATE, stronger model.
# Leave unset to use the agent's model/host for judging too. Example: keep the agent on
# llama3.1:8b but judge keyword quality with a strong model:
#   JUDGE_OLLAMA_HOST=http://localhost:11434
#   JUDGE_MODEL_ID=gpt-oss:120b-cloud
